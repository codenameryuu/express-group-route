{
    "name": "@codenameryuu/express-group-route",
    "version": "1.5.0",
    "description": "Easy route grouping for Express JS with resource api model.",
    "author": "codenameryuu",
    "license": "MIT",
    "homepage": "https://github.com/codenameryuu/express-group-route#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/codenameryuu/express-group-route.git"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "files": [
        "dist",
        "types.d.ts"
    ],
    "scripts": {
        "start": "tsup --watch",
        "build": "tsup",
        "test": "tsdx test --coverage",
        "lint": "tsdx lint",
        "size": "size-limit",
        "analyze": "size-limit --why",
        "coveralls": "cat ./coverage/lcov.info | ./node_modules/.bin/coveralls",
        "release": "standard-version"
    },
    "peerDependencies": {},
    "husky": {
        "hooks": {
            "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
        }
    },
    "prettier": {
        "printWidth": 80,
        "semi": true,
        "singleQuote": true,
        "trailingComma": "es5"
    },
    "keywords": [
        "express",
        "route",
        "group",
        "end-point",
        "resource",
        "api"
    ],
    "publishConfig": {
        "tag": "latest",
        "access": "public"
    },
    "main": "dist/express-group-route.cjs.production.min.js",
    "module": "dist/express-group-route.esm.js",
    "types": "dist/express-group-route.d.ts",
    "size-limit": [{
            "path": "dist/express-group-route.cjs.production.min.js",
            "limit": "10 KB"
        },
        {
            "path": "dist/express-group-route.esm.js",
            "limit": "10 KB"
        }
    ],
    "devDependencies": {
        "@commitlint/cli": "^12.0.1",
        "@commitlint/config-conventional": "^12.0.1",
        "@size-limit/preset-small-lib": "^11.1.4",
        "@types/express": "^5.0.6",
        "@types/lodash.camelcase": "^4.3.9",
        "@types/pluralize": "^0.0.29",
        "@types/sinon": "^17.0.3",
        "coveralls": "^3.1.1",
        "husky": "^4.3.8",
        "sinon": "^18.0.0",
        "size-limit": "^11.1.4",
        "standard-version": "^9.5.0",
        "tsdx": "^0.14.1",
        "tsup": "^8.5.0",
        "tslib": "^2.7.0",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "express": "^5.2.1",
        "express-list-routes": "^1.3.2",
        "lodash.camelcase": "^4.3.0",
        "pluralize": "^8.0.0"
    }
}